# --- SignalBackend configuration ---
PORT=8100
CORS_ORIGIN=http://localhost:3100

# Shared database (same Postgres as the TradingBackend). The signal app OWNS the
# "signal" schema and only READS the trading tables. In production, use a role
# scoped to: read/write on signal.*, SELECT-only on the trading tables.
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:5432/DBNAME"

# Own JWT secret — MUST differ from the TradingBackend's, so the two user bases
# (traders vs signal subscribers) are cryptographically separate.
JWT_SECRET=change-me-signal-secret
JWT_EXPIRES_IN_SEC=604800

# How many hours of closed signals the Signals page shows (the "last 24h").
SIGNAL_WINDOW_HOURS=24

# TradingBackend REST base — the chart proxies its candle history from here.
# Defaults to http://localhost:8000 when unset.
TRADING_API_URL=http://localhost:8000

# Shared secret for the TradingBackend's /api/market/history. MUST match that
# service's own SERVICE_TOKEN, or chart history comes back empty.
SERVICE_TOKEN=

# Design-demo fallback. When there are no live trades in the window, show recent
# real trades re-based into the window so the Signals page/chart aren't empty.
# On by default; set to 0 to disable. Self-reverses once real trades are live.
DEMO_SIGNALS=1

# Admin account for the signal-app admin dashboard — created (or promoted) on boot.
# Use a strong password in production.
SIGNAL_ADMIN_EMAIL=admin@signals.app
SIGNAL_ADMIN_PASSWORD=change-me-admin


# --- Automated copy trading (REAL MONEY) -------------------------------------
#
# BOTH of the following are DELIBERATELY LEFT UNSET, and are commented out rather
# than given a default. For these two, absent IS the safe configuration — they are
# listed here so the feature is discoverable, not so it is switched on.

# Master switch for placing real orders. Read as `=== "1"`, so ANY other value
# (unset, empty, "true", "0") means OFF.
#
# Off, the copy engine never starts, /api/copy/settings refuses to enable copying
# (503), and no order can reach a broker. On, subscribers with copy mode enabled
# have orders queued for their terminal automatically.
#
# The strictness is the point: a bad config, a restored backup or a copied .env
# must never be able to start trading someone's account by accident. Turn this on
# only deliberately, per environment, and only after a log-only run.
# COPY_EXECUTION=1

# AES-256-GCM key for broker credentials at rest (any passphrase length; it is
# SHA-256'd to 32 bytes). Unset, /api/broker/connect returns 503 and refuses to
# store anything — credentials are never written in plaintext as a fallback.
#
# Only needed for the DIRECT broker path (e.g. Tradovate). The ATAS pull flow does
# not need it: the terminal collects its own work and we never hold credentials.
#
# Changing this key makes every stored credential undecryptable — subscribers must
# reconnect their broker. Treat it as permanent once set.
# BROKER_ENC_KEY=change-me-long-random-passphrase
