{
  "name": "signal-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Counter-signal backend — mirrors the TradingBackend's trade flow (inverted) as sellable signals. Separate users; shared (read-only) trade data.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
